### PostgreSQL ###
POSTGRES_DB=runner_db
POSTGRES_USER=runner_user
POSTGRES_PASSWORD=change_me

### Symfony ###
APP_ENV=dev
APP_SECRET=change_me

### Mercure ###
MERCURE_PUBLISHER_JWT_KEY=change_me
MERCURE_SUBSCRIBER_JWT_KEY=change_me
MERCURE_PUBLIC_URL=http://localhost

### JWT (для HS256) ###
JWT_SECRET_KEY=change_me

# Если используете RSA ключи (пути абсолютные внутри контейнера)
# JWT_SECRET_KEY=/app/config/jwt/private.pem
# JWT_PUBLIC_KEY=/app/config/jwt/public.pem
# JWT_PASSPHRASE=

### Database URL ###
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?serverVersion=15&charset=utf8